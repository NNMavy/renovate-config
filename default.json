{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting",
    ":enablePreCommit",
    ":semanticCommits",
    "github>NNMavy/renovate-config:automerge-github-actions.json5",
    "github>NNMavy/renovate-config:labels.json5",
    "github>NNMavy/renovate-config:semantic-commits.json5",
    "github>NNMavy/renovate-config:generic-regex-manager.json5"
  ],
  "timezone": "Europe/Amsterdam",
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
  "commitBodyTable": true,
  "rebaseWhen": "conflicted",
  "platformCommit": true,
  "prBodyTemplate": "{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}",
  "hostRules": [
    {
      "matchHost": "ghcr.io",
      "hostType": "docker",
      "username": "NNMavy",
      "encrypted": {
        "password": ""
      }
    }
  ]
}
