{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":disableRateLimiting",
    "docker:enableMajor",
    "docker:pinDigests",
    ":automergeDigest",
    ":enablePreCommit",
    "github>NNMavy/renovate-config:automerge-github-actions.json5",
    "github>NNMavy/renovate-config:labels.json5",
    "github>NNMavy/renovate-config:semantic-commits.json5",
    "github>NNMavy/renovate-config:generic-regex-manager.json5"
  ],
  "onboarding": false,
  "requireConfig": "optional",
  "timezone": "Europe/Amsterdam",
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prIgnoreNotification"],
  "commitBodyTable": true,
  "rebaseWhen": "auto",
  "hostRules": [
    {
      "matchHost": "ghcr.io",
      "hostType": "docker",
      "username": "NNMavy",
      "password": "{{ secrets.GITHUB_COM_TOKEN }}"
    }
  ]
}
